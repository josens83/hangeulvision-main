# HangeulVision AI — Environment Variables
# Copy to .env.local and fill in for production deployments.

# Public branding
NEXT_PUBLIC_SITE_URL=https://hangeulvision.app
NEXT_PUBLIC_SITE_NAME="HangeulVision AI"

# Supabase (optional for MVP — falls back to in-memory store)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Payments — TossPayments (KR)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Payments — Paddle (Global)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PRODUCT_BASIC=
PADDLE_PRODUCT_PREMIUM=
PADDLE_PRODUCT_TOPIK_II_MID=
PADDLE_PRODUCT_TOPIK_II_ADV=
PADDLE_PRODUCT_EPS=

# AI providers
ANTHROPIC_API_KEY=
STABILITY_API_KEY=

# Email
SENDGRID_API_KEY=
SENDGRID_FROM="HangeulVision AI <no-reply@hangeulvision.app>"
