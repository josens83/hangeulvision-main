# HangeulVision AI — backend environment
# Copy to .env and fill in once the Supabase project exists.

# ─── Runtime ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,https://hangeulvision.app

# ─── Database (Supabase Postgres / Railway) ───────────────
# Example: postgresql://user:pass@db.xyz.supabase.co:5432/postgres?schema=public
DATABASE_URL=
# Pooled connection string (for serverless / edge workloads).
DATABASE_POOL_URL=

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:4000/auth/google/callback

# ─── Payments ─────────────────────────────────────────────
# TossPayments (Korea)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Paddle (Global)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PUBLIC_KEY=
PADDLE_PRODUCT_BASIC=
PADDLE_PRODUCT_PREMIUM=
PADDLE_PRODUCT_TOPIK_II_MID=
PADDLE_PRODUCT_TOPIK_II_ADV=
PADDLE_PRODUCT_EPS=

# ─── AI / Content pipelines ───────────────────────────────
ANTHROPIC_API_KEY=
STABILITY_API_KEY=

# ─── Email ────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM="HangeulVision AI <no-reply@hangeulvision.app>"

# ─── Storage (Supabase) ───────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_IMAGES=hangeulvision-images

# ─── Admin ────────────────────────────────────────────────
# Comma-separated list of admin emails (bypasses role check for MVP).
ADMIN_EMAILS=
INTERNAL_API_KEY=change-me-for-pipeline-calls
