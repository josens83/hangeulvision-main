# HangeulVision AI — backend environment
# Copy to .env once the Supabase project is wired up:
#     cp .env.example .env
#
# Supabase project: bplufwtrokacdpxwyttv  (region: ap-northeast-2 / Seoul)
# See docs/ENV_SETUP.md for step-by-step instructions.

# ─── Runtime ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,https://hangeulvision.app

# ─── Database (Supabase Postgres) ─────────────────────────
# DATABASE_URL — pooled connection (Transaction mode, port 6543).
#   Use this for normal app queries. Safe for serverless / high-concurrency.
#   Format:
#     postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   Example (replace PASSWORD):
#     postgresql://postgres.bplufwtrokacdpxwyttv:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.bplufwtrokacdpxwyttv:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# DIRECT_URL — direct (non-pooled) connection for Prisma migrations.
#   Prisma migrate requires a direct connection because the Transaction pooler
#   doesn't support prepared statements / advisory locks.
#   Option A — Session pooler on the same host (port 5432):
#     postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Option B — Direct to the database host:
#     postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres.bplufwtrokacdpxwyttv:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:4000/auth/google/callback

# ─── Payments ─────────────────────────────────────────────
# TossPayments (Korea)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Paddle (Global)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PUBLIC_KEY=
PADDLE_PRODUCT_BASIC=
PADDLE_PRODUCT_PREMIUM=
PADDLE_PRODUCT_TOPIK_II_MID=
PADDLE_PRODUCT_TOPIK_II_ADV=
PADDLE_PRODUCT_EPS=

# ─── AI / Content pipelines ───────────────────────────────
ANTHROPIC_API_KEY=
STABILITY_API_KEY=

# ─── Email ────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM="HangeulVision AI <no-reply@hangeulvision.app>"

# ─── Storage (Supabase) ───────────────────────────────────
SUPABASE_URL=https://bplufwtrokacdpxwyttv.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_IMAGES=hangeulvision-images

# ─── Admin ────────────────────────────────────────────────
# Comma-separated list of admin emails (bypasses role check for MVP).
ADMIN_EMAILS=
INTERNAL_API_KEY=change-me-for-pipeline-calls
