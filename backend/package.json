{
  "name": "hangeulvision-backend",
  "version": "0.1.0",
  "private": true,
  "description": "HangeulVision AI backend — Express + Prisma + Postgres (Supabase). Mirrors the VocaVision AI backend architecture.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npx prisma migrate deploy && (npx prisma db seed || true) && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@prisma/client": "5.22.0",
    "@types/form-data": "^2.2.1",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "form-data": "^4.0.5",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "tsx": "4.19.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/morgan": "1.9.9",
    "@types/node": "20.14.0",
    "prisma": "5.22.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
